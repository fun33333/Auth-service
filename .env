# ERP Shared Infrastructure Configuration
# ==========================================

# ------------------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------------------
POSTGRES_USER=erp_admin
POSTGRES_PASSWORD=erp_admin_password_change_me_in_prod
POSTGRES_DB=postgres
POSTGRES_PORT=5432
# Databases to create on init (comma separated)
POSTGRES_MULTIPLE_DATABASES=auth_db,hdms_db,sms_iak_db

# Database URLs (for services)
DATABASE_URL=postgresql://erp_admin:erp_admin_password_change_me_in_prod@erp_pgbouncer:6432/hdms_db
AUTH_DATABASE_URL=postgresql://erp_admin:erp_admin_password_change_me_in_prod@erp_pgbouncer:6432/auth_db
SIS_DATABASE_URL=postgresql://erp_admin:erp_admin_password_change_me_in_prod@erp_pgbouncer:6432/sms_iak_db

# Legacy DB settings for services using DB_USER/DB_PASSWORD
DB_USER=erp_admin
DB_PASSWORD=erp_admin_password_change_me_in_prod
AUTH_DB_NAME=auth_db
SIS_DB_NAME=sms_iak_db
HDMS_DB_NAME=hdms_db

# ------------------------------------------
# Service Configuration
# ------------------------------------------
DB_HOST=erp_pgbouncer
DB_PORT=6432
REDIS_PASSWORD=erp_password_change_me_in_prod
REDIS_URL=redis://:erp_password_change_me_in_prod@erp_redis:6379/1
SIS_REDIS_URL=redis://:erp_password_change_me_in_prod@erp_redis:6379/1
AUTH_REDIS_URL=redis://:erp_password_change_me_in_prod@erp_redis:6379/0
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.8.135
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://10.0.8.135
MEDIA_ROOT=/app/media

# ------------------------------------------
# Network Configuration
# ------------------------------------------
# Name of the shared network
ERP_NETWORK=erp_network

# ------------------------------------------
# Service URLs (Internal Docker Network)
# ------------------------------------------
AUTH_SERVICE_URL=http://auth-service:8000
USER_SERVICE_URL=http://user-service:8001
TICKET_SERVICE_URL=http://ticket-service:8002
COMMUNICATION_SERVICE_URL=http://communication-service:8003
FILE_SERVICE_URL=http://file-service:8005
SIS_BACKEND_URL=http://sis-backend:8010
