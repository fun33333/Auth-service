# Security
------------------------------------------
# Shared Secret Key for internal token verification
SECRET_KEY=dev-shared-secret-key-erp-system-2025
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=/etc/erp/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/etc/erp/keys/jwt_public.pem
ACCESS_TOKEN_LIFETIME=60
REFRESH_TOKEN_LIFETIME=1440

