# ========================================
# Auth-Service Root .gitignore
# (Next.js Frontend + Django Backend)
# ========================================

# ----- Python / Django (Backend) -----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# Virtual Environments
.env
.venv
env/
venv/
ENV/

# Django migrations (uncomment if you don't want to track)
# **/migrations/

# ----- Node / Next.js (Frontend) -----
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
.next/
out/

# Production build
build/

# Testing
coverage/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel

# ----- Environment Files -----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
!.env.example

# ----- IDE / Editor -----
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ----- OS Files -----
.DS_Store
Thumbs.db
Desktop.ini
*.lnk

# ----- Docker -----
# Uncomment if you don't want to track docker volumes
# docker-volumes/

# ----- Misc -----
*.pem
*.key
*.cert
